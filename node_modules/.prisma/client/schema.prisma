generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Iphone {
  id          BigInt   @id @default(autoincrement())
  nama_iphone String
  seri        String
  warna       String
  kapasitas   String
  kondisi     String
  status      String   @default("Tersedia")
  stok        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  peminjaman Peminjaman[]
}

model Peminjam {
  id           BigInt   @id @default(autoincrement())
  nama         String
  nim          String   @unique
  jurusan      String
  nomorTelepon String
  email        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  peminjaman Peminjaman[]
}

model Peminjaman {
  id BigInt @id @default(autoincrement())

  peminjamId BigInt
  iphoneId   BigInt

  tanggalPinjam  DateTime
  tanggalKembali DateTime?
  status         String    @default("Dipinjam")
  keterangan     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  peminjam Peminjam @relation(fields: [peminjamId], references: [id], onDelete: Cascade)
  iphone   Iphone   @relation(fields: [iphoneId], references: [id], onDelete: Cascade)
}
